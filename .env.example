# ============================================================================
# Chairapy Podcast — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored; this file is committed as documentation.
# ============================================================================

# --- Site URL ---------------------------------------------------------------
# Canonical URL for the site. Used for sitemap, OpenGraph, JSON-LD.
# Local dev:  http://localhost:3000
# Production: https://podcast.chairapy.org
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Spotify Web API --------------------------------------------------------
# Used by scripts/fetch-episodes.ts to pull the public episode catalog.
# Create an app at https://developer.spotify.com/dashboard
# Client Credentials flow — no user authentication required.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- ConvertKit -------------------------------------------------------------
# Used by /api/subscribe to add new email subscribers.
# Get these from https://app.convertkit.com/account_settings/advanced_settings
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# --- Plausible Analytics (optional) -----------------------------------------
# If set, Plausible script is loaded and custom events are fired.
# Leave blank in local dev to keep the console quiet.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
